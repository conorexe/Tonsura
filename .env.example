# Tonsura self-hosted config. Copy to .env and fill in. Never commit .env.

# Postgres connection string. Any Postgres 14+ works.
# On Supabase, prefer the transaction-mode pooler (port 6543); the session
# pooler (5432) caps clients at 15 on the free tier.
DATABASE_URL=postgresql://user:password@localhost:5432/tonsura

# 32-byte hex secret for AES-256-GCM encryption of upstream API keys.
# Generate with: openssl rand -hex 32
# Don't change this after you've stored keys, they become unrecoverable.
MASTER_ENCRYPTION_SECRET=

# Random secret for signing dashboard session cookies.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Dashboard login password (single operator).
ADMIN_PASSWORD=

# Gateway port (default 8787).
GATEWAY_PORT=8787
