# ── Tonsura self-hosted configuration ───────────────────────────────────────
# Copy to .env and fill in. Never commit .env.

# Postgres connection string (any Postgres 14+: local, Docker, RDS, Supabase…)
DATABASE_URL=postgresql://user:password@localhost:5432/tonsura

# 32-byte hex secret for AES-256-GCM encryption of upstream API keys.
# Generate with: openssl rand -hex 32
# CHANGING THIS makes already-stored keys undecryptable.
MASTER_ENCRYPTION_SECRET=

# Random secret for signing dashboard session cookies.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Password for the dashboard login (single operator).
ADMIN_PASSWORD=

# Port the usage gateway listens on (default 8787).
GATEWAY_PORT=8787
